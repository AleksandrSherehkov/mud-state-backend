########################################
# APPLICATION
########################################

APP_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

API_PREFIX=api
API_VERSION=1

########################################
# SWAGGER
########################################

SWAGGER_ENABLED=true

########################################
# DATABASE
########################################

# Example (local):
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DB_NAME?schema=public"

########################################
# REDIS / THROTTLE STORAGE
########################################

# Storage (memory|redis) — у dev можна memory, у prod тільки redis
THROTTLE_STORE_DRIVER=redis

THROTTLE_REDIS_URL=redis://:REDIS_PASSWORD@127.0.0.1:6379/0
THROTTLE_REDIS_PREFIX=throttle:

THROTTLE_REDIS_HEALTHCHECK=true
THROTTLE_REDIS_HEALTHCHECK_TIMEOUT_MS=1000

# Prod: true
THROTTLE_REDIS_HEALTHCHECK_STRICT=false

# Global throttler defaults
THROTTLE_TTL_SEC=60
THROTTLE_LIMIT=100

# Bounded store safety caps
THROTTLE_STORE_MAX_TTL_SEC=300
THROTTLE_STORE_MAX_KEYS=50000
THROTTLE_STORE_CLEANUP_INTERVAL_SEC=60

########################################
# JWT / TOKEN CONFIG
########################################

JWT_ISSUER=mud-state-backend
JWT_AUDIENCE=mud-state-clients

JWT_ACCESS_EXPIRES_IN=10m
JWT_REFRESH_EXPIRES_IN=7d

# Use strong random secrets (>= 32 chars). Prefer base64.
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_BASE64
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_BASE64

# server-side pepper (hex 64)
REFRESH_TOKEN_PEPPER=CHANGE_ME_64_HEX

########################################
# SESSION SECURITY
########################################

BCRYPT_SALT_ROUNDS=12

# access token sender-context binding
ACCESS_BIND_UA=true
ACCESS_BIND_IP=false

# refresh token sender-context binding
REFRESH_BIND_UA=true
REFRESH_BIND_IP=false

# anomaly policies (prod default: terminate)
ACCESS_FINGERPRINT_MISMATCH_ACTION=log
ACCESS_GEO_ASN_ANOMALY_ACTION=log
ACCESS_ANOMALY_LOG=true

AUTH_MAX_ACTIVE_SESSIONS=1

########################################
# AUTH LOCK / BRUTE FORCE
########################################

AUTH_LOCK_MAX_ATTEMPTS=10
AUTH_LOCK_BASE_SECONDS=2
AUTH_LOCK_MAX_SECONDS=300
AUTH_LOCK_WINDOW_SECONDS=900

########################################
# PASSWORD POLICY
########################################

PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=72
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

########################################
# TOKEN MAINTENANCE
########################################

TOKEN_CLEANUP_DAYS=7
TOKEN_CLEANUP_CRON=0 0 * * *

########################################
# LOGGING
########################################

LOG_DIR=logs
LOG_FILE_NAME=%DATE%.log
LOG_DATE_PATTERN=YYYY-MM-DD
LOG_ZIPPED_ARCHIVE=true
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

LOG_LEVEL=debug

PRISMA_LOG_QUERIES=false
PRISMA_QUERY_SAMPLE_RATE=0.05

########################################
# CORS / CSRF / PROXY
########################################

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Prod: false
CORS_ALLOW_NO_ORIGIN=true

CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Prod: false
CSRF_ALLOW_NO_ORIGIN=true

# In prod behind ingress: set >=1
TRUST_PROXY_HOPS=0

# Enable only if your ingress injects geo/asn headers
TRUST_PROXY_GEO_HEADERS=false
TRUSTED_PROXY_IPS=127.0.0.1

# optional marker header/value (defense-in-depth) — актуально лише якщо TRUST_PROXY_GEO_HEADERS=true
# TRUST_PROXY_GEO_MARKER_NAME=x-ingress-auth
# TRUST_PROXY_GEO_MARKER_VALUE=1

COOKIE_CROSS_SITE=false
COOKIE_SAMESITE=lax

# Strong random secret (>= 32 chars)
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET_LONG

########################################
# CSRF M2M (HMAC)
########################################

# Format:
# kid1:secret1:/api|/internal; kid2:secret2:*
# (В prod по Joi у тебя required)
CSRF_M2M_CLIENTS="svc-client1-prod-v1:CHANGE_ME_SECRET_1:/api/v1/auth; svc-adminbot-prod-v1:CHANGE_ME_SECRET_2:/api/v1"

CSRF_M2M_REPLAY_WINDOW_SEC=60
CSRF_M2M_NONCE_PREFIX=csrf:m2m:nonce:

# optional, else reuse THROTTLE_REDIS_URL
CSRF_M2M_REDIS_URL=redis://:REDIS_PASSWORD@127.0.0.1:6379/0

########################################
# AUTH DUMMY HASH (ANTI TIMING ATTACK)
########################################

# optional, but recommended to reduce user-enumeration timing differences
AUTH_DUMMY_PASSWORD_HASH=$2b$12$REPLACE_WITH_VALID_BCRYPT_HASH_60CHARS

########################################
# AUTH ENDPOINT THROTTLING
########################################

THROTTLE_AUTH_LOGIN_LIMIT=5
THROTTLE_AUTH_LOGIN_TTL_SEC=60

THROTTLE_AUTH_REGISTER_LIMIT=3
THROTTLE_AUTH_REGISTER_TTL_SEC=60

THROTTLE_AUTH_REFRESH_LIMIT=10
THROTTLE_AUTH_REFRESH_TTL_SEC=60

THROTTLE_AUTH_CSRF_LIMIT=60
THROTTLE_AUTH_CSRF_TTL_SEC=60

THROTTLE_AUTH_LOGOUT_LIMIT=3
THROTTLE_AUTH_LOGOUT_TTL_SEC=60

THROTTLE_AUTH_ME_LIMIT=30
THROTTLE_AUTH_ME_TTL_SEC=60

########################################
# USERS THROTTLING
########################################

THROTTLE_USERS_BY_ID_LIMIT=60
THROTTLE_USERS_BY_ID_TTL_SEC=60

THROTTLE_USERS_BY_EMAIL_LIMIT=20
THROTTLE_USERS_BY_EMAIL_TTL_SEC=60

THROTTLE_USERS_UPDATE_LIMIT=20
THROTTLE_USERS_UPDATE_TTL_SEC=60

THROTTLE_USERS_DELETE_LIMIT=10
THROTTLE_USERS_DELETE_TTL_SEC=60

########################################
# SESSIONS THROTTLING
########################################

THROTTLE_SESSIONS_ME_LIMIT=60
THROTTLE_SESSIONS_ME_TTL_SEC=60

THROTTLE_SESSIONS_TERMINATE_OTHERS_LIMIT=10
THROTTLE_SESSIONS_TERMINATE_OTHERS_TTL_SEC=60

THROTTLE_SESSIONS_TERMINATE_LIMIT=20
THROTTLE_SESSIONS_TERMINATE_TTL_SEC=60

THROTTLE_SESSIONS_GET_USER_LIMIT=60
THROTTLE_SESSIONS_GET_USER_TTL_SEC=60

########################################
# EMAIL THROTTLING (ANTI ENUMERATION)
########################################

THROTTLE_AUTH_LOGIN_EMAIL_LIMIT=10
THROTTLE_AUTH_LOGIN_EMAIL_TTL_SEC=300
THROTTLE_AUTH_LOGIN_EMAIL_BLOCK_SEC=300

THROTTLE_AUTH_REGISTER_EMAIL_LIMIT=5
THROTTLE_AUTH_REGISTER_EMAIL_TTL_SEC=600
THROTTLE_AUTH_REGISTER_EMAIL_BLOCK_SEC=600

########################################
# GLOBAL BURST PROTECTION
########################################

THROTTLE_UNAUTH_BURST_LIMIT=30
THROTTLE_UNAUTH_BURST_TTL_SEC=10
THROTTLE_UNAUTH_BURST_BLOCK_SEC=30